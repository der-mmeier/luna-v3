{
  "name": "der-mmeier/luna-v3",
  "description": "Luna V3 PHP Framework",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.2",
    "ext-pdo": "*",
    "vlucas/phpdotenv": "^v5.6.3"
  },
  "autoload": {
    "psr-4": {
      "Luna\\": "src/"
    }
  },
  "config": {
    "sort-packages": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "11.5.50"
  },
  "scripts": {
    "analyse": "phpstan analyse --memory-limit=512M",
    "test": "phpunit --configuration phpunit.xml",
    "check": [
      "composer dump-autoload",
      "@analyse",
      "@test",
      "composer audit"
    ]
  }
}
