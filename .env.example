APP_NAME="Luna V3"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
# APP_KEY must be set in the real .env before encrypted secrets are stored.
# Do not rotate APP_KEY while encrypted secrets exist unless they are re-encrypted.
APP_KEY=

LUNA_DB_HOST=127.0.0.1
LUNA_DB_PORT=3306
LUNA_DB_DATABASE=luna_v3
LUNA_DB_USERNAME=root
LUNA_DB_PASSWORD=
LUNA_DB_CHARSET=utf8mb4

MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=luna@example.test
MAIL_FROM_NAME="Luna V3"

CRON_SECRET=change-me-generate-a-random-cron-secret
